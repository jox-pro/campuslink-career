<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campuslink.controllers.StudentDashboardController"
            prefWidth="1100" prefHeight="700">

    <!-- TOP HEADER -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="16">
            <Label text="CampusLink Career — Student Portal" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblCurrentUser" styleClass="header-user"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" minWidth="220">
            <VBox styleClass="sidebar-header">
                <Label text="Navigation" styleClass="sidebar-title"/>
            </VBox>
            <Button fx:id="btnProfile" text="  My Profile" styleClass="sidebar-btn"
                    onAction="#handleProfile" maxWidth="Infinity"/>
            <Button fx:id="btnJobs" text="  Browse Jobs" styleClass="sidebar-btn"
                    onAction="#handleJobs" maxWidth="Infinity"/>
            <Button fx:id="btnInternships" text="  Internships" styleClass="sidebar-btn"
                    onAction="#handleInternships" maxWidth="Infinity"/>
            <Button fx:id="btnApplications" text="  My Applications" styleClass="sidebar-btn"
                    onAction="#handleApplications" maxWidth="Infinity"/>
            <Button fx:id="btnResources" text="  Resources" styleClass="sidebar-btn"
                    onAction="#handleResources" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="  Logout" styleClass="sidebar-btn-logout"
                    onAction="#handleLogout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- CENTER CONTENT -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>

</BorderPane>
