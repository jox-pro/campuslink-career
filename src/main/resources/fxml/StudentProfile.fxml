<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campuslink.controllers.StudentController">

    <VBox spacing="16" styleClass="content-area">
        <Label text="My Profile" styleClass="page-title"/>

        <VBox styleClass="section-card" spacing="12">
            <Label text="Personal Information"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
            <Separator/>

            <GridPane hgap="16" vgap="10">
                <Label text="Full Name *" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="fieldFullName" promptText="Your full name"
                           GridPane.columnIndex="1" GridPane.rowIndex="0" minWidth="280"/>

                <Label text="Email *" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="fieldEmail" promptText="your@email.com"
                           GridPane.columnIndex="1" GridPane.rowIndex="1" minWidth="280"/>

                <Label text="Phone" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="fieldPhone" promptText="+1234567890"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Course" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <TextField fx:id="fieldCourse" promptText="e.g. Computer Science"
                           GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Year of Study" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <TextField fx:id="fieldYear" promptText="1-7"
                           GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                <Label text="Skills" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <TextArea fx:id="fieldSkills" promptText="Java, Python, SQL..."
                          GridPane.columnIndex="1" GridPane.rowIndex="5" prefRowCount="3"/>

                <Label text="CV Path" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                <HBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="6">
                    <TextField fx:id="fieldCvPath" promptText="/path/to/cv.pdf" HBox.hgrow="ALWAYS"/>
                    <Button text="Browse" styleClass="btn-secondary" onAction="#handleBrowseCV"/>
                </HBox>
            </GridPane>

            <Label fx:id="profileMessage" wrapText="true" visible="false" managed="false"/>

            <HBox spacing="10">
                <Button text="Save Profile" styleClass="btn-primary" onAction="#handleSave"/>
                <Button text="Cancel" styleClass="btn-secondary" onAction="#handleCancel"/>
            </HBox>
        </VBox>
    </VBox>

</ScrollPane>
