<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campuslink.controllers.LoginController"
            styleClass="login-container">

    <top>
        <VBox styleClass="login-header">
            <Label text="CampusLink Career" styleClass="login-title"/>
            <Label text="University Career Portal" style="-fx-text-fill: #BBDEFB; -fx-font-size: 14px;"/>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="0">
            <VBox.margin>
                <Insets top="30" bottom="30" left="50" right="50"/>
            </VBox.margin>
            <VBox styleClass="login-card" spacing="14" alignment="TOP_CENTER" maxWidth="380">
                <Label text="Sign In to Your Account"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #212121;"/>
                <Separator/>

                <Label text="Username" styleClass="form-label"/>
                <TextField fx:id="usernameField" promptText="Enter your username"/>

                <Label text="Password" styleClass="form-label"/>
                <PasswordField fx:id="passwordField" promptText="Enter your password"/>

                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" visible="false" managed="false"/>

                <Button fx:id="loginBtn" text="Login" styleClass="btn-primary"
                        onAction="#handleLogin" maxWidth="Infinity" defaultButton="true"/>

                <Separator/>
                <Hyperlink fx:id="registerLink" text="New Student? Register Here"
                           onAction="#handleRegister"
                           style="-fx-text-fill: #1565C0; -fx-font-size: 13px;"/>
            </VBox>
        </VBox>
    </center>

</BorderPane>
