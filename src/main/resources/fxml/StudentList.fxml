<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.campuslink.controllers.StudentController"
      spacing="16" styleClass="content-area">

    <Label text="Student Management" styleClass="page-title"/>

    <!-- Search and actions bar -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search by name or course..." styleClass="search-field"
                   onAction="#handleSearch"/>
        <Button text="Search" styleClass="btn-secondary" onAction="#handleSearch"/>
        <Button text="Clear" styleClass="btn-secondary" onAction="#handleClearSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Add Student" styleClass="btn-success" onAction="#handleAdd"/>
        <Button text="Edit" styleClass="btn-warning" onAction="#handleEdit"/>
        <Button text="Delete" styleClass="btn-danger" onAction="#handleDelete"/>
        <Button text="Refresh" styleClass="btn-secondary" onAction="#handleRefresh"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="tableView" VBox.vgrow="ALWAYS" styleClass="section-card">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colName" text="Full Name" prefWidth="180"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
            <TableColumn fx:id="colCourse" text="Course" prefWidth="160"/>
            <TableColumn fx:id="colYear" text="Year" prefWidth="60"/>
            <TableColumn fx:id="colPhone" text="Phone" prefWidth="120"/>
            <TableColumn fx:id="colSkills" text="Skills" prefWidth="200"/>
        </columns>
        <placeholder><Label text="No students found."/></placeholder>
    </TableView>

    <Label fx:id="statusLabel" styleClass="page-subtitle"/>

</VBox>
